NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Required in all deployed environments — without this, CSRF origin validation
# is silently disabled on every API route. Set to the canonical origin,
# e.g. https://fostrfind.com (no trailing slash).
NEXT_PUBLIC_APP_URL=

# Local dev only — NEVER set this in any deployed environment (staging, preview, production).
# NEXT_PUBLIC_DEV_MODE=true

# Sentry — set after creating the Next.js project at sentry.io. The DSN
# is safe to expose (NEXT_PUBLIC_*); the auth token is build-time only,
# never shipped to the browser, and only required to upload source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
