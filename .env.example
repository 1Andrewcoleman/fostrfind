NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_APP_URL=

# Sentry — set after creating the Next.js project at sentry.io. The DSN
# is safe to expose (NEXT_PUBLIC_*); the auth token is build-time only,
# never shipped to the browser, and only required to upload source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
